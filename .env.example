# ===================================
# StockWatcher - 环境变量配置模板
# 复制为 .env 并修改配置后生效
# ===================================

# ===== 自选股与定时任务 =====
# 逗号分隔，支持 A 股（纯数字）/ 港股（代码.HK）/ 美股（代码.US）
STOCK_LIST=600519,300750,002594

# 定时分析时间 (HH:MM)
SCHEDULE_TIME=09:30

# 启用定时任务（true/false）
SCHEDULE_ENABLED=false

# 启动时立即执行一次（true/false）
RUN_IMMEDIATELY=true

# ===== LLM / AI 模型 =====
# 至少配置一项以启用 AI 解读功能

# Anspire 网关 API Key（支持多 key，逗号分隔）
ANSPIRE_API_KEYS=
# Google Gemini API Key（免费）
GEMINI_API_KEY=
# OpenAI 兼容 API Key（支持 DeepSeek、通义千问等）
OPENAI_API_KEY=
# OpenAI 兼容 API 地址，默认 https://api.openai.com/v1
OPENAI_BASE_URL=
# 模型名称，默认 gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Anspire 默认模型
LLM_MODEL=Doubao-Seed-2.0-lite
# LLM 请求超时秒数
LLM_TIMEOUT_SEC=60

# ===== 数据源 =====
# 不配置时默认使用 AkShare（A 股）/ YFinance（港股/美股）
# 配置后系统按降级链自动选择

# Tushare Pro Token（从 https://tushare.pro 获取）
TUSHARE_TOKEN=
# TickFlow API Key
TICKFLOW_API_KEY=
# Finnhub API Key（美股）
FINNHUB_API_KEY=
# Longbridge（长桥）API 凭证（A/港/美股，需 pip install longport）
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
# Baostock / Pytdx 无需 token，安装依赖后自动加入降级链

# ===== 通知渠道 =====
# 至少配置一个以接收推送

# 企业微信机器人 Webhook URL
WECHAT_WEBHOOK_URL=
# 飞书机器人 Webhook URL
FEISHU_WEBHOOK_URL=
# Telegram Bot Token（@BotFather 获取）
TELEGRAM_BOT_TOKEN=
# Telegram 接收消息的 Chat ID
TELEGRAM_CHAT_ID=
# Discord Webhook URL
DISCORD_WEBHOOK_URL=
# Slack Webhook URL
SLACK_WEBHOOK_URL=
# SMTP 邮件配置
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# ===== 代理（可选） =====
# 国内环境需要科学上网时开启
USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10809

# ===== 日志 =====
LOG_DIR=logs
LOG_LEVEL=INFO

# ===== 数据文件（自动管理） =====
PORTFOLIO_FILE=data/portfolio.json
ALERT_FILE=data/alerts.json
